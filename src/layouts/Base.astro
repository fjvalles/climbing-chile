---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n/ui';
import { ClientRouter } from 'astro:transitions';

import { getAltPath } from '../i18n/routes';

interface Props {
  lang: Lang;
  title: string;
  description?: string;
  ogImage?: string;
}
const { lang, title, description, ogImage } = Astro.props;
const siteName = 'Climbing Chile';
const currentPath = Astro.url.pathname;
const altPath = getAltPath(currentPath, lang);
const siteUrl = Astro.site || 'https://climbingchile_cl.netlify.app'; // Fallback if Astro.site is not set

const fullTitle = title.includes(siteName) ? title : `${title} · ${siteName}`;

const defaultDesc = lang === 'es' 
  ? 'Expediciones, escalada y formación técnica en los Andes de Chile. Guías certificados UIAGM/ANGM.' 
  : 'Expeditions, climbing and technical training in the Chilean Andes. Certified UIAGM/ANGM guides.';
const desc = description ?? defaultDesc;

const og = ogImage ?? '/og.jpg';
const canonical = new URL(currentPath, siteUrl).toString();
const alternate = new URL(altPath, siteUrl).toString();

const esPath = lang === 'es' ? canonical : alternate;
const enPath = lang === 'en' ? canonical : alternate;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    
    <!-- International SEO (hreflang) -->
    <link rel="alternate" hreflang="es" href={esPath} />
    <link rel="alternate" hreflang="en" href={enPath} />
    <link rel="alternate" hreflang="x-default" href={esPath} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="512x512" />
    <link rel="shortcut icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:image" content={og} />
    <meta property="og:locale" content={lang === 'es' ? 'es_CL' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <ClientRouter />
    <!-- Google Analytics 4: reemplaza G-XXXXXXXXXX con tu Measurement ID -->
    <!-- <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}gtag('js',new Date());gtag('config','G-XXXXXXXXXX');</script> -->
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="skip-link">{lang === 'es' ? 'Saltar al contenido principal' : 'Skip to main content'}</a>
    <Header lang={lang} />
    <main id="main-content" class="flex-1" tabindex="-1">
      <slot />
    </main>
    <Footer lang={lang} />
    <script>
      // If the URL contains an identity token, send it to /admin/ where
      // Decap CMS handles it natively — no need for the widget here.
      const hash = window.location.hash;
      if (
        hash.includes('invite_token') ||
        hash.includes('recovery_token') ||
        hash.includes('confirmation_token')
      ) {
        window.location.replace('/admin/' + hash);
      }
    </script>
  </body>
</html>
