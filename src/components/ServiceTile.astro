---
interface Props {
  icon: 'mountain' | 'rope' | 'book' | 'truck' | 'flag' | 'calendar';
  title: string;
  body: string;
  href?: string;
}
const { icon, title, body, href } = Astro.props;

const paths: Record<Props['icon'], string> = {
  mountain: 'M3 20 L10 8 L14 14 L18 9 L23 20 Z',
  rope: 'M4 20 C 8 4, 16 4, 20 20',
  book: 'M4 5 H11 A3 3 0 0 1 14 8 V20 A3 3 0 0 0 11 17 H4 Z M14 8 A3 3 0 0 1 17 5 H22 V17 H17 A3 3 0 0 0 14 20',
  truck: 'M2 7 H14 V17 H2 Z M14 10 H19 L22 13 V17 H14 Z M6 17 A2 2 0 1 0 6 21 A2 2 0 0 0 6 17 Z M18 17 A2 2 0 1 0 18 21 A2 2 0 0 0 18 17 Z',
  flag: 'M5 3 V21 M5 4 H17 L15 8 L17 12 H5',
  calendar: 'M3 6 H21 V20 H3 Z M3 10 H21 M8 3 V8 M16 3 V8',
};
const d = paths[icon];

const Tag = href ? 'a' : 'div';
---
<Tag
  href={href}
  class="group relative p-8 bg-white border border-[var(--color-line)] hover:border-[var(--color-ink)] transition-colors block"
>
  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round" stroke-linecap="round" class="text-[var(--color-ink)] group-hover:text-[var(--color-brand-yellow-dark)] transition-colors">
    <path d={d} />
  </svg>
  <h3 class="display text-xl mt-6">{title}</h3>
  <p class="mt-3 text-sm text-[var(--color-stone)] leading-relaxed">{body}</p>
  {href && (
    <span class="absolute top-8 right-8 text-[var(--color-ink)] opacity-0 group-hover:opacity-100 transition-opacity">→</span>
  )}
</Tag>
