---
import Base from "../layouts/Base.astro";
import Hero from "./Hero.astro";
import SectionHeader from "./SectionHeader.astro";
import ExpeditionCard from "./ExpeditionCard.astro";
import CourseCard from "./CourseCard.astro";
import CTABanner from "./CTABanner.astro";
import TestimonialsSection from "./TestimonialsSection.astro";
import WhatsAppBubble from "./WhatsAppBubble.astro";
import { useTranslations, type Lang } from "../i18n/ui";
import { r } from "../i18n/routes";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const expeditions = (await getCollection("expeditions"))
  .filter((e) => e.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6);

const courses = (await getCollection("courses")).sort(
  (a, b) => a.data.order - b.data.order,
);

const team = (await getCollection("team")).sort(
  (a, b) => a.data.order - b.data.order,
);

const site = await getEntry("site", "config");
if (!site) throw new Error("Site config not found");

const title =
  lang === "es"
    ? "Climbing Chile · Guías de montaña"
    : "Climbing Chile · Mountain Guides";
---

<Base lang={lang} title={title}>
  <Hero lang={lang} />

  <section
    id="expeditions"
    class="py-20 md:py-28 bg-white border-y border-[var(--color-line)]"
  >
    <div class="max-w-7xl mx-auto px-5 md:px-8">
      <div class="flex flex-wrap items-end justify-between gap-6 md:flex-nowrap">
        <SectionHeader
          eyebrow={t("section.expeditions")}
          title={t("section.expeditions.title")}
        />
        <a href={r(lang, "calendar")} class="btn btn-outline whitespace-nowrap"
          >{t("section.expeditions.all")} →</a
        >
      </div>

      <div class="flex flex-wrap gap-2 mt-10">
        <button
          class="filter-btn uppercase text-xs font-bold tracking-widest bg-[var(--color-ink)] text-[var(--color-bone)] px-4 py-2 rounded-full border border-[var(--color-ink)] transition-colors"
          data-filter="all">{lang === "es" ? "TODAS" : "ALL"}</button
        >
        <button
          class="filter-btn uppercase text-xs font-bold tracking-widest bg-transparent text-[var(--color-ink)] px-4 py-2 rounded-full border border-[var(--color-line)] hover:border-[var(--color-ink)] transition-colors"
          data-filter="region-chile">CHILE</button
        >
        <button
          class="filter-btn uppercase text-xs font-bold tracking-widest bg-transparent text-[var(--color-ink)] px-4 py-2 rounded-full border border-[var(--color-line)] hover:border-[var(--color-ink)] transition-colors"
          data-filter="region-internacional"
          >{lang === "es" ? "INTERNACIONAL" : "INTERNATIONAL"}</button
        >
      </div>

      <div
        class="mt-8 mobile-carousel md:grid md:grid-cols-2 lg:grid-cols-3 md:gap-5"
        id="expeditions-grid"
        data-carousel-track
      >
        {expeditions.map((e) => (
          <div class="carousel-slide">
            <ExpeditionCard entry={e} lang={lang} />
          </div>
        ))}
      </div>
      <div
        class="carousel-dots mt-5 md:hidden"
        data-carousel-dots
        aria-label={lang === "es" ? "Paginación de expediciones" : "Expeditions pagination"}
      ></div>
    </div>
  </section>

  <section id="training" class="py-20 md:py-28 bg-[var(--color-bone)]">
    <div class="max-w-7xl mx-auto px-5 md:px-8">
      <div class="flex flex-wrap items-end justify-between gap-6 md:flex-nowrap">
        <SectionHeader
          eyebrow={t("section.training")}
          title={t("section.training.title")}
        />
      </div>
      <div
        class="mt-14 mobile-carousel md:grid md:grid-cols-2 lg:grid-cols-3 md:gap-5"
        data-carousel-track
      >
        {courses.map((e) => (
          <div class="carousel-slide">
            <CourseCard entry={e} lang={lang} />
          </div>
        ))}
      </div>
      <div
        class="carousel-dots mt-5 md:hidden"
        data-carousel-dots
        aria-label={lang === "es" ? "Paginación de cursos" : "Courses pagination"}
      ></div>
    </div>
  </section>

  <section
    id="about"
    class="py-20 md:py-28 bg-white border-y border-[var(--color-line)]"
  >
    <div class="max-w-7xl mx-auto px-5 md:px-8">
      <div class="max-w-5xl">
        <SectionHeader
          eyebrow={t("section.about")}
          title={site.data.about.title[lang]}
        />
      </div>

      <div class="mt-12 grid gap-10 lg:grid-cols-2 lg:gap-16 items-start">
        <div class="space-y-8">
          {site.data.about.values.map((v) => (
            <div class="border-l-2 border-[var(--color-brand-yellow)] pl-4">
              <p class="display text-3xl">{v.title[lang]}</p>
              <p class="text-sm text-[var(--color-stone)] mt-2">
                {v.body[lang]}
              </p>
            </div>
          ))}
        </div>

        <div class="space-y-6 self-start">
          {
            team.map((p) => (
              <article class="flex flex-col gap-6 p-6 md:p-8 bg-[var(--color-bone)] border border-[var(--color-line)] transition-all sm:flex-row sm:items-start hover:border-[var(--color-brand-yellow)] hover:shadow-sm">
                <div class="shrink-0 w-32 h-32 overflow-hidden rounded-full border-4 border-white shadow-md mx-auto sm:mx-0">
                  <Image
                    src={p.data.photo}
                    alt={p.data.name}
                    widths={[200, 400]}
                    class="w-full h-full object-cover"
                  />
                </div>
                <div class="flex-1 text-center sm:text-left">
                  <div>
                    <p class="display text-3xl">{p.data.name}</p>
                    <p class="eyebrow text-[var(--color-brand-yellow-dark)] mt-1">
                      {p.data.role[lang]}
                    </p>
                  </div>
                  <p class="text-sm text-[var(--color-stone)] mt-4 leading-relaxed">
                    {p.data.bio[lang]}
                  </p>
                  {p.data.certifications.length > 0 && (
                    <div class="flex flex-wrap justify-center sm:justify-start gap-2 mt-4">
                      {p.data.certifications.map((c) => (
                        <span class="tape text-[10px] px-2 py-1">
                          {c}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <TestimonialsSection lang={lang} />
  <CTABanner lang={lang} />
  <WhatsAppBubble />
</Base>

<script>
  const btns = document.querySelectorAll(".filter-btn");
  const cards = document.querySelectorAll(
    ".expedition-card",
  ) as NodeListOf<HTMLElement>;

  btns.forEach((btn) => {
    btn.addEventListener("click", () => {
      btns.forEach((b) => {
        b.classList.remove("bg-[var(--color-ink)]", "text-[var(--color-bone)]");
        b.classList.add("bg-transparent", "text-[var(--color-ink)]");
      });
      btn.classList.remove("bg-transparent", "text-[var(--color-ink)]");
      btn.classList.add("bg-[var(--color-ink)]", "text-[var(--color-bone)]");

      const filter = btn.getAttribute("data-filter");

      cards.forEach((card) => {
        if (filter === "all") {
          card.style.display = "";
        } else if (
          filter === "status-open" &&
          card.getAttribute("data-status") === "open"
        ) {
          card.style.display = "";
        } else if (
          filter === "status-soon" &&
          card.getAttribute("data-status") === "soon"
        ) {
          card.style.display = "";
        } else if (
          filter === "region-chile" &&
          card.getAttribute("data-region") === "chile"
        ) {
          card.style.display = "";
        } else if (
          filter === "region-internacional" &&
          card.getAttribute("data-region") === "internacional"
        ) {
          card.style.display = "";
        } else {
          card.style.display = "none";
        }
      });
    });
  });

  const mobileCarouselQuery = window.matchMedia("(max-width: 767px)");
  const allCarousels = document.querySelectorAll<HTMLElement>("[data-carousel-track]");

  const setupCarousel = (carousel: HTMLElement) => {
    const slides = Array.from(
      carousel.querySelectorAll<HTMLElement>(".carousel-slide"),
    ).filter((slide) => slide.offsetParent !== null);
    const dotsContainer = carousel.nextElementSibling as HTMLElement | null;
    const autoPlay = carousel.hasAttribute("data-auto-carousel");

    if (slides.length < 1) {
      return;
    }

    let timer: number | undefined;
    let resumeTimer: number | undefined;

    const getVisibleSlides = () =>
      slides.filter((slide) => slide.offsetParent !== null);

    const getCurrentIndex = (visibleSlides = getVisibleSlides()) => {
      if (visibleSlides.length === 0) {
        return 0;
      }

      const currentIndex = visibleSlides.findIndex((slide, index) => {
        const isLast = index === visibleSlides.length - 1;
        const slideStart = slide.offsetLeft - carousel.offsetLeft;
        const slideEnd = slideStart + slide.offsetWidth;
        const point = carousel.scrollLeft + carousel.clientWidth * 0.35;

        if (isLast) {
          return point >= slideStart;
        }

        return point >= slideStart && point < slideEnd;
      });

      return currentIndex < 0 ? 0 : currentIndex;
    };

    const updateDots = () => {
      if (!dotsContainer) {
        return;
      }

      const visibleSlides = getVisibleSlides();
      const activeIndex = getCurrentIndex(visibleSlides);
      const dots = dotsContainer.querySelectorAll<HTMLButtonElement>("[data-carousel-dot]");

      dots.forEach((dot, index) => {
        const isActive = index === activeIndex;
        dot.setAttribute("aria-current", isActive ? "true" : "false");
        dot.classList.toggle("is-active", isActive);
      });
    };

    const renderDots = () => {
      if (!dotsContainer) {
        return;
      }

      const visibleSlides = getVisibleSlides();
      dotsContainer.innerHTML = "";

      if (visibleSlides.length < 2 || !mobileCarouselQuery.matches) {
        return;
      }

      visibleSlides.forEach((_, index) => {
        const dot = document.createElement("button");
        dot.type = "button";
        dot.className = "carousel-dot";
        dot.setAttribute("data-carousel-dot", "");
        dot.setAttribute(
          "aria-label",
          `${index + 1} / ${visibleSlides.length}`,
        );
        dot.addEventListener("click", () => {
          pauseAndResume();
          carousel.scrollTo({
            left: visibleSlides[index].offsetLeft - carousel.offsetLeft,
            behavior: "smooth",
          });
        });
        dotsContainer.append(dot);
      });

      updateDots();
    };

    const clearTimers = () => {
      if (timer) {
        window.clearInterval(timer);
        timer = undefined;
      }
      if (resumeTimer) {
        window.clearTimeout(resumeTimer);
        resumeTimer = undefined;
      }
    };

    const start = () => {
      if (!autoPlay || !mobileCarouselQuery.matches || document.hidden) {
        return;
      }

      clearTimers();
      timer = window.setInterval(() => {
        const visibleSlides = getVisibleSlides();
        if (visibleSlides.length < 2) {
          return;
        }

        const currentIndex = getCurrentIndex(visibleSlides);
        const nextIndex =
          currentIndex < 0 || currentIndex >= visibleSlides.length - 1
            ? 0
            : currentIndex + 1;

        carousel.scrollTo({
          left: visibleSlides[nextIndex].offsetLeft - carousel.offsetLeft,
          behavior: "smooth",
        });
      }, 3800);
    };

    const pauseAndResume = () => {
      clearTimers();

      if (!autoPlay || !mobileCarouselQuery.matches) {
        return;
      }

      resumeTimer = window.setTimeout(start, 5500);
    };

    carousel.addEventListener("pointerdown", pauseAndResume, { passive: true });
    carousel.addEventListener("touchstart", pauseAndResume, { passive: true });
    carousel.addEventListener(
      "scroll",
      () => {
        updateDots();
        pauseAndResume();
      },
      { passive: true },
    );

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) {
        clearTimers();
      } else {
        renderDots();
        start();
      }
    });

    mobileCarouselQuery.addEventListener("change", () => {
      clearTimers();
      renderDots();
      start();
    });

    renderDots();
    start();
  };

  allCarousels.forEach(setupCarousel);

  const heroVideo = document.querySelector<HTMLVideoElement>("[data-hero-video]");

  const tryPlayHero = () => {
    if (!heroVideo) {
      return;
    }

    heroVideo.muted = true;
    heroVideo.defaultMuted = true;

    const playback = heroVideo.play();
    if (playback) {
      playback.catch(() => {});
    }
  };

  if (heroVideo) {
    heroVideo.addEventListener("canplay", tryPlayHero, { once: true });
    heroVideo.addEventListener("loadeddata", tryPlayHero, { once: true });
    document.addEventListener("visibilitychange", () => {
      if (!document.hidden) {
        tryPlayHero();
      }
    });
    tryPlayHero();
  }
</script>
