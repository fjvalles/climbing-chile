---
import { getEntry } from 'astro:content';
const footerEntry = await getEntry('site', 'footer');
if (!footerEntry || footerEntry.data.type !== 'footer') return null;
const phone = footerEntry.data.whatsapp.replace(/\D/g, '');
const msg = encodeURIComponent('Hola Climbing Chile 👋, me gustaría saber más.');
---
<a
  href={`https://wa.me/${phone}?text=${msg}`}
  target="_blank"
  rel="noopener"
  aria-label="WhatsApp Climbing Chile"
  class="fixed bottom-5 right-5 z-50 bg-[#25D366] text-white rounded-full w-14 h-14 flex items-center justify-center shadow-lg hover:scale-110 transition-transform"
>
  <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M17.5 14.4c-.3-.2-1.8-.9-2.1-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.2-.2.2-.3.2-.6.1-1.8-.9-3-1.6-4.2-3.7-.3-.6.3-.5.9-1.7.1-.2 0-.4 0-.5-.1-.2-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1 2.8 1.2 3c.2.2 2.1 3.2 5.1 4.5 1.9.8 2.6.9 3.5.7.5-.1 1.8-.7 2-1.4.3-.7.3-1.3.2-1.4-.1-.1-.3-.2-.6-.3zM12 2a10 10 0 0 0-8.7 15l-1.3 4.7 4.8-1.2A10 10 0 1 0 12 2z"/>
  </svg>
</a>
