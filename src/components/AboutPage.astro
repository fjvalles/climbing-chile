---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import CTABanner from './CTABanner.astro';
import WhatsAppBubble from './WhatsAppBubble.astro';
import { useTranslations, type Lang } from '../i18n/ui';
import { getCollection } from 'astro:content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const team = (await getCollection('team')).sort((a, b) => a.data.order - b.data.order);

const intro = lang === 'es'
  ? 'Climbing Chile nace en Santiago con una obsesión: hacer la cordillera accesible sin atajos. Somos un equipo de guías de montaña con décadas de experiencia combinada en los Andes y una red de colaboradores certificados en toda Sudamérica.'
  : "Climbing Chile was born in Santiago with one obsession: making the Andes accessible without shortcuts. We're a team of mountain guides with decades of combined experience in the Andes and a network of certified partners across South America.";
const manifestoTitle = lang === 'es' ? 'Nuestra forma de hacer montaña' : 'How we do mountains';
const manifesto = lang === 'es' ? [
  { h: 'Grupos reducidos', b: 'Ratios bajos guía/cliente para seguridad y calidad de experiencia.' },
  { h: 'Material cuidado', b: 'Revisamos cada pieza. Cuerdas, crampones, piolets siempre en regla.' },
  { h: 'Seguridad sobre cumbre', b: 'Si las condiciones no están, bajamos. La montaña siempre estará ahí.' },
  { h: 'Comunidad climber', b: 'No somos solo servicio: organizamos eventos, compartimos conocimiento.' },
] : [
  { h: 'Small groups', b: 'Low guide/client ratios for safety and a better experience.' },
  { h: 'Dialed gear', b: 'We inspect every item. Ropes, crampons, axes — always in shape.' },
  { h: 'Safety over summit', b: "If conditions aren't there, we turn around. The mountain will still be there." },
  { h: 'Climber community', b: "We're not just a service: we host events, share knowledge." },
];
---
<Base lang={lang} title={t('nav.about')}>
  <section class="bg-[var(--color-ink)] text-[var(--color-bone)] py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-5 md:px-8">
      <p class="eyebrow text-[var(--color-brand-yellow)]">{t('section.about')}</p>
      <h1 class="display text-5xl md:text-7xl mt-6 max-w-4xl">{t('section.about.title')}</h1>
      <p class="mt-8 max-w-2xl text-lg text-[var(--color-stone-light)] leading-relaxed">{intro}</p>
    </div>
  </section>

  <section class="py-20 md:py-28 bg-[var(--color-bone)]">
    <div class="max-w-7xl mx-auto px-5 md:px-8">
      <p class="eyebrow text-[var(--color-brand-yellow-dark)]">{t('about.values.title')}</p>
      <h2 class="display text-4xl md:text-5xl mt-4">{manifestoTitle}</h2>
      <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {manifesto.map((m) => (
          <div class="bg-white p-6 border border-[var(--color-line)]">
            <p class="display text-xl">{m.h}</p>
            <p class="text-sm text-[var(--color-stone)] mt-3">{m.b}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {team.length > 0 && (
    <section class="py-20 md:py-28 bg-white border-t border-[var(--color-line)]">
      <div class="max-w-7xl mx-auto px-5 md:px-8">
        <p class="eyebrow text-[var(--color-brand-yellow-dark)]">{lang === 'es' ? 'El equipo' : 'The team'}</p>
        <h2 class="display text-4xl md:text-5xl mt-4">{lang === 'es' ? 'Guías y colaboradores' : 'Guides & partners'}</h2>
        <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {team.map((p) => (
            <article class="bg-[var(--color-bone)] border border-[var(--color-line)] overflow-hidden">
              <div class="aspect-square overflow-hidden bg-[var(--color-ink)]">
                <Image src={p.data.photo} alt={p.data.name} widths={[400, 600]} class="w-full h-full object-cover" />
              </div>
              <div class="p-6">
                <p class="display text-xl">{p.data.name}</p>
                <p class="eyebrow text-[var(--color-stone)] mt-1">{p.data.role[lang]}</p>
                <p class="text-sm text-[var(--color-stone)] mt-4">{p.data.bio[lang]}</p>
                {p.data.certifications.length > 0 && (
                  <div class="flex flex-wrap gap-2 mt-4">
                    {p.data.certifications.map((c) => <span class="tape text-[10px]">{c}</span>)}
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <CTABanner lang={lang} />
  <WhatsAppBubble />
</Base>
