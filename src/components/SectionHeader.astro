---
interface Props {
  eyebrow: string;
  title: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, align = 'left' } = Astro.props;
---
<div
  class:list={[
    'w-full min-w-0',
    align === 'center' && 'mx-auto text-center',
  ]}
>
  <p class="eyebrow text-[var(--color-brand-yellow-dark)]">{eyebrow}</p>
  <h2 class="display mt-4 text-[clamp(2rem,4.4vw,4.1rem)] leading-[0.9]">
    {title}
  </h2>
</div>
