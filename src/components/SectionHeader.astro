---
interface Props {
  eyebrow: string;
  title: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, align = 'left' } = Astro.props;
---
<div class:list={['max-w-3xl', align === 'center' && 'mx-auto text-center']}>
  <p class="eyebrow text-[var(--color-brand-yellow-dark)]">{eyebrow}</p>
  <h2 class="display text-4xl md:text-5xl lg:text-6xl mt-4">{title}</h2>
</div>
