---
import { useTranslations, type Lang } from '../i18n/ui';
import { r } from '../i18n/routes';
import { getEntry } from 'astro:content';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const site = await getEntry('site', 'config');
const s = site?.data;
const waHref = s ? `https://wa.me/${s.whatsapp.replace(/\D/g, '')}` : '#';
---
<section class="relative overflow-hidden bg-[var(--color-ink)] text-[var(--color-bone)]">
  <div class="absolute inset-0" aria-hidden="true">
    <video
      autoplay
      loop
      muted
      playsinline
      preload="auto"
      data-hero-video
      class="w-full h-full object-cover"
    >
      <source src="/hero-bg.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-black/50 mix-blend-multiply"></div>
    <div class="absolute inset-0 bg-[var(--color-ink)] opacity-40"></div>
  </div>
  <div class="relative max-w-7xl mx-auto px-5 md:px-8 pt-20 md:pt-32 pb-24 md:pb-40">
    <p class="eyebrow text-[var(--color-brand-yellow)]">{t('hero.eyebrow')}</p>
    <h1 class="display text-4xl md:text-7xl mt-6 md:whitespace-pre-line max-w-4xl">
      {t('hero.title')}
    </h1>
    <p class="mt-8 max-w-xl text-base md:text-lg text-[var(--color-stone-light)] leading-relaxed">
      {t('hero.subtitle')}
    </p>
    <div class="mt-10 flex flex-wrap gap-3">
      <a href={r(lang, 'expeditions')} class="btn btn-primary">{t('hero.cta.primary')} →</a>
      <a href={waHref} target="_blank" rel="noopener" class="btn btn-outline hover:bg-[#25D366] hover:border-[#25D366]" style="border-color: var(--color-bone); color: var(--color-bone)">{t('hero.cta.secondary')}</a>
    </div>
  </div>
  <div class="divider-ticks absolute bottom-0 inset-x-0" style="background-image: repeating-linear-gradient(90deg, var(--color-brand-yellow) 0 12px, transparent 12px 24px);"></div>
</section>
