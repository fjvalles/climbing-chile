---
import { useTranslations, type Lang } from '../i18n/ui';
import { r } from '../i18n/routes';
import { getEntry } from 'astro:content';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const site = await getEntry('site', 'footer');
const hero = await getEntry('site', 'hero');
const s = site?.data;
const h = hero?.data;
const waInquiryMessage = lang === 'es'
  ? 'Hola, quisiera cotizar una expedición con Climbing Chile.'
  : 'Hi, I\'d like a quote for an expedition with Climbing Chile.';
const waHref = s
  ? `https://wa.me/${s.whatsapp.replace(/\D/g, '')}?text=${encodeURIComponent(waInquiryMessage)}`
  : '#';
const summitFrames = h?.backgroundFrames ?? [];
const heroHighlightFallback = {
  es: 'con tus sueños',
  en: 'to your mountain',
} as const;
const heroHighlight = (h?.titleHighlight?.[lang] ?? heroHighlightFallback[lang]).trim();
---
<section class="relative overflow-hidden bg-[var(--color-ink)] text-[var(--color-bone)]">
  <div class="absolute inset-0" aria-hidden="true">
    <div class="hero-film absolute inset-0">
      {summitFrames.map((frame, index) => (
        <div
          class="hero-film__frame"
          style={`background-image: url(${frame.image.src}); background-position: ${frame.position}; animation-delay: ${index * (18 / summitFrames.length)}s;`}
        ></div>
      ))}
    </div>
    <div class="absolute inset-0 bg-black/50 mix-blend-multiply"></div>
    <div class="absolute inset-0 bg-[var(--color-ink)] opacity-40"></div>
    <div class="absolute inset-0 hero-film__glow"></div>
  </div>
  <div class="relative max-w-7xl mx-auto px-5 md:px-8 pt-20 md:pt-32 pb-24 md:pb-40">
    <p class="eyebrow text-[var(--color-brand-yellow)]">{h?.eyebrow[lang]}</p>
    <h1 class="display text-[clamp(1.75rem,8vw,4.5rem)] leading-[1.1] md:leading-[0.95] mt-6 whitespace-pre-wrap max-w-4xl break-words [text-wrap:balance]">{(() => {
        const titleText = h?.title[lang] || '';
        const escapedHeroHighlight = heroHighlight.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        return titleText
          .split(new RegExp(`(${escapedHeroHighlight})`, 'gi'))
          .map((part) =>
            heroHighlight.length > 0 && part.toLowerCase() === heroHighlight.toLowerCase() ? (
              <span class="text-[var(--color-brand-yellow)]">{part}</span>
            ) : (
              part
            )
          );
      })()}</h1>
    <p class="mt-8 max-w-xl text-base md:text-lg text-[var(--color-stone-light)] leading-relaxed [text-wrap:pretty]">
      {h?.subtitle[lang]}
    </p>
    <div class="mt-10 flex flex-wrap gap-3">
      <a href={r(lang, 'expeditions')} class="btn btn-primary btn-shimmer">{h?.primaryButton[lang]} →</a>
      <a href={waHref} target="_blank" rel="noopener" class="btn btn-whatsapp-outline flex items-center gap-2">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.2-1.8-.9-2.1-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.2-.2.2-.3.2-.6.1-1.8-.9-3-1.6-4.2-3.7-.3-.6.3-.5.9-1.7.1-.2 0-.4 0-.5-.1-.2-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1 2.8 1.2 3c.2.2 2.1 3.2 5.1 4.5 1.9.8 2.6.9 3.5.7.5-.1 1.8-.7 2-1.4.3-.7.3-1.3.2-1.4-.1-.1-.3-.2-.6-.3zM12 2a10 10 0 0 0-8.7 15l-1.3 4.7 4.8-1.2A10 10 0 1 0 12 2z"/></svg>
        {h?.secondaryButton[lang]}
      </a>
    </div>
  </div>
  <div class="divider-ticks absolute bottom-0 inset-x-0" style="background-image: repeating-linear-gradient(90deg, var(--color-brand-yellow) 0 12px, transparent 12px 24px);"></div>
</section>

<style>
  .hero-film {
    overflow: hidden;
  }

  .hero-film__frame {
    position: absolute;
    inset: 0;
    background-repeat: no-repeat;
    background-size: cover;
    opacity: 0;
    transform: scale(1.02);
    animation: hero-film-cycle 18s infinite ease-in-out;
    will-change: transform, opacity;
  }

  .hero-film__glow {
    background:
      radial-gradient(circle at 18% 30%, rgb(247 193 68 / 0.22), transparent 28%),
      linear-gradient(180deg, rgb(12 18 25 / 0.05) 0%, rgb(12 18 25 / 0.35) 100%);
  }

  @keyframes hero-film-cycle {
    0% {
      opacity: 0;
      transform: scale(1.02);
    }

    8% {
      opacity: 1;
    }

    28% {
      opacity: 1;
      transform: scale(1.1);
    }

    36% {
      opacity: 0;
      transform: scale(1.14);
    }

    100% {
      opacity: 0;
      transform: scale(1.14);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-film__frame {
      animation: none;
      opacity: 0;
      transform: none;
    }

    .hero-film__frame:first-child {
      opacity: 1;
    }
  }
</style>
