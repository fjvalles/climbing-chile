---
import Base from '../layouts/Base.astro';
import WhatsAppBubble from './WhatsAppBubble.astro';
import { useTranslations, type Lang } from '../i18n/ui';
import { getEntry } from 'astro:content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const site = await getEntry('site', 'config');
const s = site?.data;
const waHref = s ? `https://wa.me/${s.whatsapp.replace(/\D/g, '')}` : '#';
const formAction = s?.formEndpoint ?? '';
---
<Base lang={lang} title={t('contact.title')}>
  <section class="bg-[var(--color-ink)] text-[var(--color-bone)] py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-5 md:px-8">
      <p class="eyebrow text-[var(--color-brand-yellow)]">{t('nav.contact')}</p>
      <h1 class="display text-5xl md:text-7xl mt-6">{t('contact.title')}</h1>
      <p class="mt-6 max-w-xl text-lg text-[var(--color-stone-light)]">{t('contact.subtitle')}</p>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-5 md:px-8 grid lg:grid-cols-12 gap-10">
      <aside class="lg:col-span-5 space-y-4">
        {s && (
          <>
            <a href={waHref} target="_blank" rel="noopener" class="block bg-[#25D366] text-white p-6 border border-transparent hover:bg-[#1ea855] transition-colors">
              <p class="eyebrow">{t('contact.whatsapp')}</p>
              <p class="display text-2xl mt-2">{s.whatsappDisplay}</p>
              <p class="text-sm mt-2 opacity-90">{lang === 'es' ? 'Respuesta más rápida' : 'Fastest reply'}</p>
            </a>
            <a href={`mailto:${s.email}`} class="block bg-[var(--color-ink)] text-[var(--color-brand-yellow)] p-6 hover:bg-[var(--color-ink-soft)] transition-colors">
              <p class="eyebrow">{t('contact.email')}</p>
              <p class="display text-2xl mt-2 break-all">{s.email}</p>
            </a>
            <a href={s.instagram} target="_blank" rel="noopener" class="block bg-[var(--color-brand-yellow)] text-[var(--color-ink)] p-6 hover:bg-[var(--color-brand-yellow-light)] transition-colors">
              <p class="eyebrow">Instagram</p>
              <p class="display text-2xl mt-2">@climbingchile_cl</p>
            </a>
          </>
        )}
      </aside>

      <form id="contact-form" action={formAction} method="POST" class="lg:col-span-7 space-y-5 bg-white p-8 border border-[var(--color-line)]">
        <div class="grid md:grid-cols-2 gap-5">
          <label class="block">
            <span class="eyebrow text-[var(--color-stone)]">{t('contact.form.name')} *</span>
            <input required type="text" name="name" class="mt-2 w-full border-b border-[var(--color-ink)] bg-transparent py-2 focus:outline-none focus:border-[var(--color-brand-yellow-dark)]" />
          </label>
          <label class="block">
            <span class="eyebrow text-[var(--color-stone)]">{t('contact.form.email')} *</span>
            <input required type="email" name="email" class="mt-2 w-full border-b border-[var(--color-ink)] bg-transparent py-2 focus:outline-none focus:border-[var(--color-brand-yellow-dark)]" />
          </label>
        </div>
        <label class="block">
          <span class="eyebrow text-[var(--color-stone)]">{t('contact.form.phone')}</span>
          <input type="tel" name="phone" class="mt-2 w-full border-b border-[var(--color-ink)] bg-transparent py-2 focus:outline-none focus:border-[var(--color-brand-yellow-dark)]" />
        </label>
        <label class="block">
          <span class="eyebrow text-[var(--color-stone)]">{t('contact.form.subject')}</span>
          <select name="subject" class="mt-2 w-full border-b border-[var(--color-ink)] bg-transparent py-2 focus:outline-none focus:border-[var(--color-brand-yellow-dark)]">
            <option>{t('contact.form.subject.expedition')}</option>
            <option>{t('contact.form.subject.training')}</option>
            <option>{t('contact.form.subject.tailor')}</option>
            <option>{t('contact.form.subject.other')}</option>
          </select>
        </label>
        <label class="block">
          <span class="eyebrow text-[var(--color-stone)]">{t('contact.form.message')} *</span>
          <textarea required name="message" rows="5" class="mt-2 w-full border-b border-[var(--color-ink)] bg-transparent py-2 focus:outline-none focus:border-[var(--color-brand-yellow-dark)] resize-none"></textarea>
        </label>
        <input type="hidden" name="_language" value={lang} />
        <button type="submit" class="btn btn-dark w-full md:w-auto">
          <span data-label="idle">{t('contact.form.submit')}</span>
          <span data-label="sending" class="hidden">{t('contact.form.sending')}</span>
        </button>
        <p id="form-status" class="text-sm hidden" data-success={t('contact.form.success')} data-error={t('contact.form.error')}></p>
      </form>
    </div>
  </section>
  <WhatsAppBubble />
</Base>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status') as HTMLParagraphElement | null;
  if (form && status) {
    form.addEventListener('submit', async (e) => {
      if (!form.action || form.action.includes('your-form-id')) return;
      e.preventDefault();
      const btn = form.querySelector('button[type=submit]') as HTMLButtonElement;
      btn.querySelector('[data-label=idle]')?.classList.add('hidden');
      btn.querySelector('[data-label=sending]')?.classList.remove('hidden');
      btn.disabled = true;
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        status.classList.remove('hidden');
        if (res.ok) {
          status.textContent = status.dataset.success ?? '';
          status.className = 'text-sm text-green-700';
          form.reset();
        } else {
          status.textContent = status.dataset.error ?? '';
          status.className = 'text-sm text-red-700';
        }
      } catch {
        status.classList.remove('hidden');
        status.textContent = status.dataset.error ?? '';
        status.className = 'text-sm text-red-700';
      } finally {
        btn.querySelector('[data-label=idle]')?.classList.remove('hidden');
        btn.querySelector('[data-label=sending]')?.classList.add('hidden');
        btn.disabled = false;
      }
    });
  }
</script>
