---
import Logo from './Logo.astro';
import { useTranslations, type Lang } from '../i18n/ui';
import { r, altLang } from '../i18n/routes';
import { getEntry } from 'astro:content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const alt = altLang(lang);
const current = Astro.url.pathname;
const site = await getEntry('site', 'footer');
const header = await getEntry('site', 'header');
const s = site?.data;
const h = header?.data;
const waHref = s ? `https://wa.me/${s.whatsapp.replace(/\D/g, '')}` : '#';

const nav = [
  { key: 'nav.expeditions' as const, href: r(lang, 'expeditions') },
  { key: 'nav.training' as const, href: r(lang, 'training') },
  { key: 'nav.about' as const, href: r(lang, 'about') },
  { key: 'nav.calendar' as const, href: r(lang, 'calendar') },
];

const langAltHref = current === '/' ? r(alt, 'home') : current.startsWith('/en') ? current.replace(/^\/en/, '') || '/' : `/en${current === '/' ? '' : current}`;
---
<header class="sticky top-0 z-40 bg-[var(--color-bone)]/90 backdrop-blur border-b border-[var(--color-line)]">
  <div class="max-w-7xl mx-auto px-5 md:px-8 h-16 md:h-20 flex items-center justify-between">
    <Logo />
    <nav class="hidden md:flex items-center gap-8 h-full" aria-label="Primary">
      {nav.map(({ key, href }) => (
        key === 'nav.calendar' ? (
          <a
            href={href}
            class:list={[
              'eyebrow text-xs px-3 py-1.5 border transition-colors',
              current === href
                ? 'border-[var(--color-brand-yellow-dark)] bg-[var(--color-brand-yellow)] text-[var(--color-ink)]'
                : 'border-[var(--color-brand-yellow-dark)] text-[var(--color-brand-yellow-dark)] hover:bg-[var(--color-brand-yellow)] hover:text-[var(--color-ink)]',
            ]}
          >
            {t(key)}
          </a>
        ) : (
          <a
            href={href}
            class:list={[
              'nav-link',
              current === href && 'nav-link--active',
            ]}
          >
            {t(key)}
          </a>
        )
      ))}
    </nav>
    <div class="flex items-center gap-3">
      <a href={langAltHref} id="lang-switch" class="eyebrow text-[var(--color-stone)] hover:text-[var(--color-ink)]" aria-label={t('lang.switch')}>
        {alt.toUpperCase()}
      </a>
      <div class="hidden md:flex">
        <a href={waHref} target="_blank" rel="noopener" class="btn btn-primary bg-[#25D366] hover:bg-[#1ea855] border-transparent text-white">
          {h?.bookButton[lang]}
        </a>
      </div>
      <button id="nav-toggle" class="md:hidden p-2" aria-label="Menu" aria-expanded="false">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="4" y1="7" x2="20" y2="7" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="17" x2="20" y2="17" />
        </svg>
      </button>
    </div>
  </div>
  <div id="mobile-nav" class="md:hidden hidden border-t border-[var(--color-line)] bg-[var(--color-bone)]">
    <div class="px-5 py-4 flex flex-col gap-3">
      {nav.map(({ key, href }) => (
        key === 'nav.calendar' ? (
          <a href={href} class="eyebrow text-xs self-start px-3 py-1.5 border border-[var(--color-brand-yellow-dark)] text-[var(--color-brand-yellow-dark)] hover:bg-[var(--color-brand-yellow)] hover:text-[var(--color-ink)] transition-colors">{t(key)}</a>
        ) : (
          <a href={href} class="display text-lg py-1 transition-colors hover:text-[var(--color-brand-yellow-dark)]">{t(key)}</a>
        )
      ))}
      <a href={waHref} target="_blank" rel="noopener" class="btn btn-primary w-full mt-2 bg-[#25D366] hover:bg-[#1ea855] border-transparent text-white">{h?.bookButton[lang]}</a>
    </div>
  </div>
</header>
<script>
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });

  // When user manually switches language, remember their choice for 1 year
  // so the auto-redirect edge function won't override it.
  document.getElementById('lang-switch')?.addEventListener('click', () => {
    document.cookie = 'lang-pref=manual; max-age=31536000; path=/; SameSite=Lax';
  });
</script>
