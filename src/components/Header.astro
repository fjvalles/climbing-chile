---
import Logo from './Logo.astro';
import { useTranslations, type Lang } from '../i18n/ui';
import { r, getAltPath } from '../i18n/routes';
import { getEntry } from 'astro:content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const current = Astro.url.pathname;
const site = await getEntry('site', 'footer');
const header = await getEntry('site', 'header');
const s = site?.data;
const h = header?.data;
const waInquiryMessage = lang === 'es'
  ? 'Hola, quisiera más información sobre Climbing Chile.'
  : 'Hi, I\'d like more information about Climbing Chile.';
const waHref = s
  ? `https://wa.me/${s.whatsapp.replace(/\D/g, '')}?text=${encodeURIComponent(waInquiryMessage)}`
  : '#';

const nav = [
  { label: h?.nav.expeditions[lang] ?? t('nav.expeditions'), href: r(lang, 'expeditions'), isPill: false },
  { label: h?.nav.training[lang] ?? t('nav.training'), href: r(lang, 'training'), isPill: false },
  { label: h?.nav.about[lang] ?? t('nav.about'), href: r(lang, 'about'), isPill: false },
  { label: h?.nav.calendar[lang] ?? t('nav.calendar'), href: r(lang, 'calendar'), isPill: true },
];

const langAltHref = getAltPath(current, lang);
---
<header class="sticky top-0 z-40 bg-[var(--color-bone)]/90 backdrop-blur border-b border-[var(--color-line)]">
  <div class="max-w-7xl mx-auto px-5 md:px-8 h-16 md:h-20 flex items-center justify-between">
    <Logo lang={lang} />
    <nav class="hidden md:flex items-center gap-8 h-full" aria-label="Primary">
      {nav.map(({ label, href, isPill }) => (
        isPill ? (
          <a
            href={href}
            class:list={[
              'eyebrow text-xs px-3 py-1.5 border transition-colors',
              current === href
                ? 'border-[var(--color-brand-yellow-dark)] bg-[var(--color-brand-yellow)] text-[var(--color-ink)]'
                : 'border-[var(--color-brand-yellow-dark)] text-[var(--color-brand-yellow-dark)] hover:bg-[var(--color-brand-yellow)] hover:text-[var(--color-ink)]',
            ]}
          >
            {label}
          </a>
        ) : (
          <a
            href={href}
            class:list={[
              'nav-link',
              current === href && 'nav-link--active',
            ]}
          >
            {label}
          </a>
        )
      ))}
    </nav>
    <div class="flex items-center gap-3">
      <div class="inline-flex lang-toggle" aria-label={lang === 'es' ? 'Selector de idioma' : 'Language selector'}>
        {lang === 'es' ? (
          <>
            <span class="lang-toggle__active eyebrow" aria-current="true">ES</span>
            <a href={langAltHref} data-lang-switch class="lang-toggle__option eyebrow" aria-label={t('lang.switch')}>EN</a>
          </>
        ) : (
          <>
            <a href={langAltHref} data-lang-switch class="lang-toggle__option eyebrow" aria-label={t('lang.switch')}>ES</a>
            <span class="lang-toggle__active eyebrow" aria-current="true">EN</span>
          </>
        )}
      </div>
      <div class="hidden md:flex">
        <a href={waHref} target="_blank" rel="noopener" class="btn text-[var(--color-whatsapp-dark)] border border-[var(--color-whatsapp)] hover:bg-[var(--color-whatsapp)] hover:text-white hover:border-[var(--color-whatsapp)] flex items-center gap-2">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.2-1.8-.9-2.1-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.2-.2.2-.3.2-.6.1-1.8-.9-3-1.6-4.2-3.7-.3-.6.3-.5.9-1.7.1-.2 0-.4 0-.5-.1-.2-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1 2.8 1.2 3c.2.2 2.1 3.2 5.1 4.5 1.9.8 2.6.9 3.5.7.5-.1 1.8-.7 2-1.4.3-.7.3-1.3.2-1.4-.1-.1-.3-.2-.6-.3zM12 2a10 10 0 0 0-8.7 15l-1.3 4.7 4.8-1.2A10 10 0 1 0 12 2z"/></svg>
                  {h?.bookButton[lang]}
                </a>
      </div>
      <button id="nav-toggle" class="md:hidden p-2" aria-label="Menu" aria-expanded="false">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="4" y1="7" x2="20" y2="7" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="17" x2="20" y2="17" />
        </svg>
      </button>
    </div>
  </div>
  <div id="mobile-nav" class="md:hidden hidden border-t border-[var(--color-line)] bg-[var(--color-bone)]">
    <div class="px-5 py-4 flex flex-col gap-3">
      {nav.map(({ label, href, isPill }) => (
        isPill ? (
          <a href={href} class="eyebrow text-xs self-start px-3 py-1.5 border border-[var(--color-brand-yellow-dark)] text-[var(--color-brand-yellow-dark)] hover:bg-[var(--color-brand-yellow)] hover:text-[var(--color-ink)] transition-colors">{label}</a>
        ) : (
          <a href={href} class="display text-lg py-1 transition-colors hover:text-[var(--color-brand-yellow-dark)]">{label}</a>
        )
      ))}
      <a href={waHref} target="_blank" rel="noopener" class="btn btn-whatsapp btn-shimmer w-full mt-2">{h?.bookButton[lang]}</a>
    </div>
  </div>
</header>
<script>
  function initNav() {
    const toggle = document.getElementById('nav-toggle');
    const nav = document.getElementById('mobile-nav');
    
    if (toggle && nav) {
      // Remove previous listener to avoid multiple registrations
      const newToggle = toggle.cloneNode(true) as HTMLElement;
      toggle.parentNode?.replaceChild(newToggle, toggle);

      newToggle.addEventListener('click', () => {
        const isOpen = nav.classList.toggle('hidden') === false;
        newToggle.setAttribute('aria-expanded', String(isOpen));
      });
    }

    // Language switch listener
    document.querySelectorAll('[data-lang-switch]').forEach((link) => {
      link.addEventListener('click', () => {
        document.cookie = 'lang-pref=manual; max-age=31536000; path=/; SameSite=Lax';
      });
    });
  }

  // Initialize on page load (fires on initial load and after view transitions)
  document.addEventListener('astro:page-load', initNav);
</script>
