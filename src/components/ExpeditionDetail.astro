---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import CTABanner from './CTABanner.astro';
import { useTranslations, type Lang } from '../i18n/ui';
import { r } from '../i18n/routes';
import { getEntry, type CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'expeditions'>;
  lang: Lang;
}
const { entry, lang } = Astro.props;
const t = useTranslations(lang);
const d = entry.data;
const footerEntry = await getEntry('site', 'footer');
const waMessage =
  lang === 'es'
    ? `Hola, me interesa la expedición "${d.title[lang]}".`
    : `Hi, I'm interested in the expedition "${d.title[lang]}".`;
const wa = footerEntry && footerEntry.data.type === 'footer'
  ? `https://wa.me/${footerEntry.data.whatsapp.replace(/\D/g, '')}?text=${encodeURIComponent(waMessage)}`
  : '#';
const detailParagraphs = d.details ? d.details[lang].split(/\n\n+/).map(p => p.trim()).filter(Boolean) : [];

function getYouTubeId(url: string): string | null {
  const m = url.match(/(?:youtube\.com\/(?:watch\?v=|shorts\/)|youtu\.be\/)([^&\n?#]+)/);
  return m ? m[1] : null;
}
const videoId = d.video ? getYouTubeId(d.video) : null;

const difficultyLabel = {
  es: { easy: 'Fácil', moderate: 'Moderada', demanding: 'Exigente', difficult: 'Difícil', expedition: 'Expedición' },
  en: { easy: 'Easy', moderate: 'Moderate', demanding: 'Demanding', difficult: 'Difficult', expedition: 'Expedition' },
} as const;
const includesLabel = lang === 'es' ? 'Incluye' : 'Includes';
const excludesLabel = lang === 'es' ? 'No incluye' : 'Does not include';
const itineraryLabel = lang === 'es' ? 'Itinerario' : 'Itinerary';
const dayLabel = lang === 'es' ? 'Día' : 'Day';
const fromLabel = lang === 'es' ? 'Desde' : 'From';
---
<Base lang={lang} title={d.title[lang]} description={d.summary[lang]}>
  <article>
    <section class="relative h-[60vh] min-h-[480px] overflow-hidden bg-[var(--color-ink)]">
      <Image src={d.cover} alt={d.title[lang]} widths={[800, 1400, 2000]} sizes="100vw" class="absolute inset-0 w-full h-full object-cover opacity-80" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
      <div class="absolute inset-x-0 bottom-0 max-w-7xl mx-auto px-5 md:px-8 py-14 text-[var(--color-bone)]">
        <p class="eyebrow text-[var(--color-brand-yellow)]">{d.location[lang]}</p>
        <h1 class="display text-5xl md:text-7xl mt-4 max-w-4xl">{d.title[lang]}</h1>
      </div>
    </section>

    <section class="bg-white border-b border-[var(--color-line)]">
      <div class="max-w-7xl mx-auto px-5 md:px-8 py-8 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-6 items-start">
        <div>
          <p class="eyebrow text-[var(--color-stone)]">{t('card.duration')}</p>
          <p class="display text-2xl mt-2">{d.durationDays} {lang === 'es' ? 'DÍAS' : 'DAYS'}</p>
        </div>
        <div>
          <p class="eyebrow text-[var(--color-stone)]">{t('card.difficulty')}</p>
          <p class="display text-2xl mt-2">{difficultyLabel[lang][d.difficulty]}</p>
        </div>
        {d.maxSpots && (
          <div>
            <p class="eyebrow text-[var(--color-stone)]">{t('card.maxSpots')}</p>
            <p class="display text-2xl mt-2">{d.maxSpots}</p>
          </div>
        )}
        {d.priceFrom && (
          <div>
            <p class="eyebrow text-[var(--color-stone)]">{fromLabel}</p>
            <p class="display text-2xl mt-2">{d.currency} {d.priceFrom.toLocaleString()}</p>
          </div>
        )}
        <div>
          <p class="eyebrow text-[var(--color-stone)]">{t('card.season')}</p>
          <p class="display text-2xl mt-2">{d.season[lang]}</p>
        </div>
        <div class="hidden md:flex items-start">
          <a href={wa} target="_blank" rel="noopener" class="btn btn-shimmer w-full btn-whatsapp flex items-center justify-center gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.2-1.8-.9-2.1-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.2-.2.2-.3.2-.6.1-1.8-.9-3-1.6-4.2-3.7-.3-.6.3-.5.9-1.7.1-.2 0-.4 0-.5-.1-.2-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1 2.8 1.2 3c.2.2 2.1 3.2 5.1 4.5 1.9.8 2.6.9 3.5.7.5-.1 1.8-.7 2-1.4.3-.7.3-1.3.2-1.4-.1-.1-.3-.2-.6-.3zM12 2a10 10 0 0 0-8.7 15l-1.3 4.7 4.8-1.2A10 10 0 1 0 12 2z"/></svg>
            {t('expedition.book')}
          </a>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-24">
      <div class="max-w-7xl mx-auto px-5 md:px-8 grid lg:grid-cols-12 gap-10">
        <div class="lg:col-span-7">
          <p class="text-xl md:text-2xl leading-relaxed">{d.summary[lang]}</p>
          {detailParagraphs.length > 0 && (
            <div class="mt-8 space-y-4">
              {detailParagraphs.map(p => <p class="text-base leading-relaxed text-[var(--color-stone)]">{p}</p>)}
            </div>
          )}

          {videoId && (
            <div class="mt-12">
              <p class="eyebrow text-[var(--color-brand-yellow-dark)] mb-4">{lang === 'es' ? 'Video' : 'Video'}</p>
              <div class="relative w-full aspect-video bg-black">
                <iframe
                  src={`https://www.youtube-nocookie.com/embed/${videoId}`}
                  title={d.title[lang]}
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  loading="lazy"
                  class="absolute inset-0 w-full h-full"
                ></iframe>
              </div>
            </div>
          )}

          {d.itinerary.length > 0 && (
            <>
              <h2 class="display text-3xl md:text-4xl mt-16">{itineraryLabel}</h2>
              <ol class="mt-8 space-y-6 border-l border-[var(--color-line)]">
                {d.itinerary.map((step) => (
                  <li class="pl-6 relative">
                    <span class="absolute -left-[7px] top-2 w-3 h-3 bg-[var(--color-brand-yellow)] rounded-full"></span>
                    <p class="eyebrow text-[var(--color-stone)]">{dayLabel} {step.day}</p>
                    <p class="display text-xl mt-1">{step.title[lang]}</p>
                    <p class="text-sm text-[var(--color-stone)] mt-2 max-w-prose">{step.body[lang]}</p>
                  </li>
                ))}
              </ol>
            </>
          )}
        </div>

        <aside class="lg:col-span-5 space-y-6">
          {d.includes && (
            <div class="bg-[var(--color-bone)] p-6 border border-[var(--color-line)]">
              <p class="eyebrow text-[var(--color-brand-yellow-dark)]">{includesLabel}</p>
              <ul class="mt-4 space-y-2 text-sm">
                {d.includes[lang].map((i: string) => <li class="flex gap-2"><span class="text-[var(--color-brand-yellow-dark)]">✓</span>{i}</li>)}
              </ul>
            </div>
          )}
          {d.excludes && (
            <div class="bg-[var(--color-bone)] p-6 border border-[var(--color-line)]">
              <p class="eyebrow text-[var(--color-stone)]">{excludesLabel}</p>
              <ul class="mt-4 space-y-2 text-sm">
                {d.excludes[lang].map((i: string) => <li class="flex gap-2"><span class="text-[var(--color-stone)]">—</span>{i}</li>)}
              </ul>
            </div>
          )}
          <a href={r(lang, 'calendar')} class="btn btn-outline w-full">{t('expedition.dates')} →</a>
        </aside>
      </div>
    </section>
  </article>

  {/* Sticky CTA for Mobile */}
  <div class="fixed bottom-0 inset-x-0 z-40 lg:hidden bg-white/95 backdrop-blur-sm border-t border-[var(--color-line)] p-4 shadow-[0_-10px_30px_rgba(0,0,0,0.05)]">
    <a href={wa} target="_blank" rel="noopener" class="btn btn-shimmer w-full btn-whatsapp py-4 text-base flex items-center justify-center gap-3">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.2-1.8-.9-2.1-1-.3-.1-.5-.2-.7.2-.2.3-.8 1-.9 1.2-.2.2-.3.2-.6.1-1.8-.9-3-1.6-4.2-3.7-.3-.6.3-.5.9-1.7.1-.2 0-.4 0-.5-.1-.2-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1 2.8 1.2 3c.2.2 2.1 3.2 5.1 4.5 1.9.8 2.6.9 3.5.7.5-.1 1.8-.7 2-1.4.3-.7.3-1.3.2-1.4-.1-.1-.3-.2-.6-.3zM12 2a10 10 0 0 0-8.7 15l-1.3 4.7 4.8-1.2A10 10 0 1 0 12 2z"/></svg>
      {t('expedition.book')}
    </a>
  </div>

  <CTABanner lang={lang} />
</Base>
