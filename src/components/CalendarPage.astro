---
import Base from '../layouts/Base.astro';
import { type Lang } from '../i18n/ui';
import { getEntry, getCollection } from 'astro:content';

interface Props { lang: Lang }
const { lang } = Astro.props;
const title = lang === 'es' ? 'Calendario de Actividades' : 'Activities Calendar';

const site = await getEntry('site', 'footer');
const waNumber = site?.data?.whatsapp.replace(/\D/g, '') || '';

// Fetch all activities
const expeditions = await getCollection('expeditions');
const courses = await getCollection('courses');

// Combine and extract dates
const allActivitiesRaw = [...expeditions, ...courses].flatMap(entry => {
  const dates = entry.data.dates || [];
  return dates.map(date => ({
    date: date.start, // Keep for sorting/grouping
    startDate: date.start,
    endDate: date.end,
    title: entry.data.title[lang],
    price: `${entry.data.currency} $${entry.data.priceFrom?.toLocaleString()}`,
    spots: date.spots || entry.data.maxSpots || entry.data.maxStudents || 0,
    available: date.spots !== undefined ? date.spots : (entry.data.maxSpots || entry.data.maxStudents || 0),
    href: lang === 'es' 
      ? `/${'durationDays' in entry.data && 'level' in entry.data ? 'formacion' : 'expediciones'}/${entry.data.slug || entry.id}`
      : `/en/${'durationDays' in entry.data && 'level' in entry.data ? 'training' : 'expeditions'}/${entry.data.slug || entry.id}`
  }));
});

// Deduplicate by date + base title
const seen = new Set();
const allActivities = allActivitiesRaw.filter(a => {
  // Normalize title for deduplication (e.g., "Escalada en hielo..." -> "Escalada en hielo")
  const baseTitle = a.title.split('·')[0].trim().toLowerCase();
  const key = `${a.startDate}-${a.endDate}-${baseTitle}`;
  
  if (seen.has(key)) return false;
  seen.add(key);
  return true;
});

// Sort by date
allActivities.sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

// Group by Month Year
const groupedActivities = allActivities.reduce((acc, curr) => {
  const dateObj = new Date(curr.date);
  let monthYear = dateObj.toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-US', { month: 'long', year: 'numeric' });
  monthYear = monthYear.charAt(0).toUpperCase() + monthYear.slice(1);
  if (!acc[monthYear]) {
    acc[monthYear] = [];
  }
  acc[monthYear].push(curr);
  return acc;
}, {} as Record<string, typeof allActivities>);

const parseDate = (dateStr: string) => {
  const [year, month, day] = dateStr.split('-').map(Number);
  return new Date(year, month - 1, day);
};

const formatDateRange = (startStr: string, endStr: string) => {
  const start = parseDate(startStr);
  const end = parseDate(endStr);
  const locale = lang === 'es' ? 'es-ES' : 'en-US';
  const options: Intl.DateTimeFormatOptions = { day: '2-digit', month: '2-digit', year: 'numeric' };

  if (startStr === endStr) {
    return start.toLocaleDateString(locale, options);
  }

  return `${start.toLocaleDateString(locale, options)} - ${end.toLocaleDateString(locale, options)}`;
};

---
<Base lang={lang} title={title}>
  <section class="bg-[var(--color-ink)] text-[var(--color-bone)] py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-5 md:px-8">
      <h1 class="display text-5xl md:text-7xl">{title}</h1>
    </div>
  </section>
  <section class="py-16 md:py-24 bg-[var(--color-bone)] min-h-[50vh]">
    <div class="max-w-7xl mx-auto px-5 md:px-8 text-[var(--color-stone)]">
      {Object.entries(groupedActivities).length === 0 && (
        <p class="text-xl">{lang === 'es' ? 'No hay actividades programadas.' : 'No activities scheduled.'}</p>
      )}
      {Object.entries(groupedActivities).map(([month, acts]) => (
        <div class="mb-14 last:mb-0">
          <h2 class="display text-3xl text-[var(--color-ink)] mb-6 border-b border-[var(--color-brand-yellow)] inline-block pb-1 pr-6">{month}</h2>
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="border-b-2 border-[var(--color-line)] text-sm uppercase tracking-widest text-[var(--color-ink)]">
                  <th class="py-4 px-4 font-bold">{lang === 'es' ? 'Fecha' : 'Date'}</th>
                  <th class="py-4 px-4 font-bold">{lang === 'es' ? 'Actividad' : 'Activity'}</th>
                  <th class="py-4 px-4 font-bold">{lang === 'es' ? 'Precio' : 'Price'}</th>
                  <th class="py-4 px-4 font-bold">{lang === 'es' ? 'Cupos' : 'Spots'}</th>
                  <th class="py-4 px-4 font-bold text-center">{lang === 'es' ? 'Acción' : 'Action'}</th>
                </tr>
              </thead>
              <tbody>
                {acts.map((a) => {
                  const displayDate = formatDateRange(a.startDate, a.endDate);
                  const msg = lang === 'es' 
                    ? `Hola! Me gustaría reservar un cupo para la actividad: ${a.title} con fecha ${displayDate}.`
                    : `Hi! I would like to book a spot for the activity: ${a.title} on ${displayDate}.`;
                  const waHref = waNumber ? `https://wa.me/${waNumber}?text=${encodeURIComponent(msg)}` : '#';
                  return (
                    <tr class="border-b border-[var(--color-line)] hover:bg-white transition-colors">
                      <td class="py-4 px-4 whitespace-nowrap text-[var(--color-ink)]">{displayDate}</td>
                      <td class="py-4 px-4 font-medium text-[var(--color-ink)]">
                        {a.href && a.href !== '#' ? (
                          <a href={a.href} class="group inline-flex items-center gap-1.5 hover:text-[var(--color-brand-yellow-dark)] transition-colors underline decoration-[var(--color-line)] underline-offset-4 hover:decoration-[var(--color-brand-yellow-dark)]">
                            {a.title}
                            <span class="opacity-50 group-hover:opacity-100 transition-opacity">↗</span>
                          </a>
                        ) : (
                          a.title
                        )}
                      </td>
                      <td class="py-4 px-4">{a.price}</td>
                      <td class="py-4 px-4">{a.available > 0 ? a.available : (lang === 'es' ? 'Agotado' : 'Full')}</td>
                      <td class="py-4 px-4 text-center">
                        {a.available > 0 ? (
                          <a href={waHref} target="_blank" rel="noopener" class="inline-block bg-[#25D366] text-white px-4 py-2 text-xs font-bold uppercase tracking-widest hover:bg-[#1ea855] transition-colors rounded-sm">
                            {lang === 'es' ? 'Reservar' : 'Book'}
                          </a>
                        ) : (
                          <span class="inline-block bg-[var(--color-line)] text-[var(--color-stone-light)] px-4 py-2 text-xs font-bold uppercase tracking-widest rounded-sm cursor-not-allowed opacity-70">
                            {lang === 'es' ? 'Agotado' : 'Sold out'}
                          </span>
                        )}
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </div>
      ))}
    </div>
  </section>
</Base>
