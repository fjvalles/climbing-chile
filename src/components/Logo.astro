---
import { Image } from 'astro:assets';
import { getEntry } from 'astro:content';

interface Props {
  variant?: 'dark' | 'light';
  class?: string;
}
const { variant = 'dark', class: className = '' } = Astro.props;
const site = await getEntry('site', 'config');

const textColor = variant === 'dark' ? '#0B0B0B' : '#F7F5F0';
const accent = '#F2C200';

if (!site) return null;
---
<a href="/" aria-label="Climbing Chile — Inicio" class={`inline-flex items-center gap-3 ${className}`}>
  <Image
    src={site.data.logo}
    alt="Climbing Chile logo"
    width={120}
    height={120}
    quality={100}
    format="webp"
    loading="eager"
    class="w-13 h-13 object-contain"
  />
  <span class="flex flex-col leading-[0.9]">
    <span class="display text-[1.05rem]" style={`color:${textColor}`}>{site.data.logoText.top}</span>
    <span class="display text-[1.05rem]" style={`color:${accent}`}>{site.data.logoText.bottom}</span>
  </span>
</a>
