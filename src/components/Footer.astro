---
import Logo from "./Logo.astro";
import type { Lang } from "../i18n/ui";
import { r } from "../i18n/routes";
import { getEntry } from "astro:content";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const footerEntry = await getEntry("site", "footer");
const headerEntry = await getEntry("site", "header");
const f = footerEntry?.data;
const h = headerEntry?.data;
const year = new Date().getFullYear();

const nav = [
  { label: f?.nav.expeditions[lang], href: r(lang, "expeditions") },
  { label: f?.nav.training[lang], href: r(lang, "training") },
  { label: f?.nav.about[lang], href: r(lang, "about") },
  { label: f?.nav.testimonials[lang], href: r(lang, "testimonials") },
  { label: f?.nav.customPlan[lang], href: r(lang, "custom_plan") },
  { label: f?.nav.calendar[lang], href: r(lang, "calendar") },
];
---

<footer class="bg-[var(--color-ink)] text-[var(--color-bone)]">
  <div class="max-w-7xl mx-auto px-5 md:px-8 py-16 grid md:grid-cols-12 gap-10">
    <div class="md:col-span-5">
      <Logo variant="light" lang={lang} />
      {
        f && f.type === 'footer' && (
          <p
            class="mt-6 text-sm text-[var(--color-stone-light)] whitespace-pre-line max-w-xs"
          >
            {f.tagline[lang]}
          </p>
        )
      }
    </div>
    <div class="md:col-span-3">
      <p class="eyebrow text-[var(--color-brand-yellow)] mb-4">
        {f?.navHeading[lang]}
      </p>
      <ul class="space-y-2">
        {
          nav.map(({ label, href }) => (
            <li>
              <a
                class="text-sm transition-colors hover:text-[var(--color-brand-yellow-dark)]"
                href={href}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <div class="md:col-span-4">
      <p class="eyebrow text-[var(--color-brand-yellow)] mb-4">
        {f?.contactHeading[lang]}
      </p>
      {
        f && f.type === 'footer' && (
          <ul class="space-y-2 text-sm">
            <li>
              <a
                href={`https://wa.me/${f.whatsapp.replace(/\D/g, "")}`}
                class="transition-colors hover:text-[#25D366]"
                target="_blank"
                rel="noopener"
              >
                {f.contactLabels.whatsapp[lang]} · {f.whatsappDisplay}
              </a>
            </li>
            <li>
              <a
                href={f.instagram}
                class="transition-colors hover:text-[var(--color-brand-yellow)]"
                target="_blank"
                rel="noopener"
              >
                {f.contactLabels.instagram[lang]} · {f.instagramDisplay}
              </a>
            </li>
            <li>
              <a
                href={`mailto:${f.email}`}
                class="transition-colors hover:text-[var(--color-brand-yellow)]"
              >
                {f.contactLabels.email[lang]} · {f.email}
              </a>
            </li>
          </ul>
        )
      }
    </div>
  </div>
  <div class="border-t border-[var(--color-ink-soft)]">
    <div
      class="max-w-7xl mx-auto px-5 md:px-8 py-6 pb-20 md:pb-6 grid md:grid-cols-3 items-center gap-4 text-xs text-[var(--color-stone-light)]"
    >
      <p class="text-center md:text-left">© {year} {h && h.type === 'header' ? `${h.logoText.top} ${h.logoText.bottom}` : 'Climbing Chile'}. {f?.rights[lang]}</p>
      
      <div class="flex items-center justify-center gap-4 text-[10px] uppercase tracking-widest">
        <a href={r(lang, "terms")} class="hover:text-[var(--color-brand-yellow)] transition-colors">{f?.nav.terms[lang]}</a>
        <span class="opacity-30">·</span>
        <a href={r(lang, "privacy")} class="hover:text-[var(--color-brand-yellow)] transition-colors">{f?.nav.privacy[lang]}</a>
      </div>

      <p class="text-center md:text-right">
        {f?.designedBy[lang]} <a href={f?.creditUrl} target="_blank" rel="noopener" class="hover:text-[var(--color-brand-yellow)] transition-colors underline underline-offset-2">{f?.creditName}</a>
      </p>
    </div>
  </div>
</footer>
