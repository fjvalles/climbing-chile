---
import Logo from "./Logo.astro";
import { useTranslations, type Lang } from "../i18n/ui";
import { r } from "../i18n/routes";
import { getEntry } from "astro:content";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const footerEntry = await getEntry("site", "footer");
const headerEntry = await getEntry("site", "header");
const f = footerEntry?.data;
const h = headerEntry?.data;
const year = new Date().getFullYear();

const nav = [
  { key: "nav.expeditions" as const, href: r(lang, "expeditions") },
  { key: "nav.training" as const, href: r(lang, "training") },
  { key: "nav.about" as const, href: r(lang, "about") },
  { key: "nav.calendar" as const, href: r(lang, "calendar") },
  { key: "nav.terms" as const, href: r(lang, "terms") },
];
---

<footer class="bg-[var(--color-ink)] text-[var(--color-bone)]">
  <div class="max-w-7xl mx-auto px-5 md:px-8 py-16 grid md:grid-cols-12 gap-10">
    <div class="md:col-span-5">
      <Logo variant="light" />
      {
        f && f.type === 'footer' && (
          <p
            class="mt-6 text-sm text-[var(--color-stone-light)] whitespace-pre-line max-w-xs"
          >
            {f.tagline[lang]}
          </p>
        )
      }
    </div>
    <div class="md:col-span-3">
      <p class="eyebrow text-[var(--color-brand-yellow)] mb-4">
        {t("footer.nav")}
      </p>
      <ul class="space-y-2">
        {
          nav.map(({ key, href }) => (
            <li>
              <a
                class="text-sm transition-colors hover:text-[var(--color-brand-yellow-dark)]"
                href={href}
              >
                {t(key)}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <div class="md:col-span-4">
      <p class="eyebrow text-[var(--color-brand-yellow)] mb-4">
        {t("footer.contact")}
      </p>
      {
        f && f.type === 'footer' && (
          <ul class="space-y-2 text-sm">
            <li>
              <a
                href={`https://wa.me/${f.whatsapp.replace(/\D/g, "")}`}
                class="transition-colors hover:text-[#25D366]"
                target="_blank"
                rel="noopener"
              >
                WhatsApp · {f.whatsappDisplay}
              </a>
            </li>
            <li>
              <a
                href={f.instagram}
                class="transition-colors hover:text-[var(--color-brand-yellow)]"
                target="_blank"
                rel="noopener"
              >
                Instagram · @climbingchile_cl
              </a>
            </li>
            <li>
              <a
                href={`mailto:${f.email}`}
                class="transition-colors hover:text-[var(--color-brand-yellow)]"
              >
                Email · {f.email}
              </a>
            </li>
          </ul>
        )
      }
    </div>
  </div>
  <div class="border-t border-[var(--color-ink-soft)]">
    <div
      class="max-w-7xl mx-auto px-5 md:px-8 py-6 pb-20 md:pb-6 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-[var(--color-stone-light)]"
    >
      <p>© {year} {h && h.type === 'header' ? `${h.logoText.top} ${h.logoText.bottom}` : 'Climbing Chile'}. {t("footer.rights")}</p>
      <p class="eyebrow">{f && f.type === 'footer' ? f.locations[lang] : ''}</p>
    </div>
  </div>
</footer>
