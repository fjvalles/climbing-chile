---
import Base from '../layouts/Base.astro';
import { type Lang } from '../i18n/ui';
import { getEntry } from 'astro:content';
import { marked } from 'marked';

interface Props { lang: Lang }
const { lang } = Astro.props;
const entry = await getEntry('site', 'terms');
if (!entry) throw new Error('Terms content not found');

const { title, content } = entry.data;
const htmlContent = marked.parse(content[lang]);
---
<Base lang={lang} title={title[lang]}>
  <section class="bg-[var(--color-ink)] text-[var(--color-bone)] py-20 md:py-28">
    <div class="max-w-4xl mx-auto px-5 md:px-8">
      <h1 class="display text-5xl md:text-7xl">{title[lang]}</h1>
    </div>
  </section>
  <section class="py-16 md:py-24 bg-[var(--color-bone)]">
    <div class="max-w-4xl mx-auto px-5 md:px-8 prose prose-stone lg:prose-xl text-[var(--color-stone)]" set:html={htmlContent} />
  </section>
</Base>
