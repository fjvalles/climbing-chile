---
import Base from '../layouts/Base.astro';
import { r } from '../i18n/routes';
---
<Base lang="es" title="Mensaje enviado · Climbing Chile">
  <section class="min-h-[60vh] flex items-center">
    <div class="max-w-7xl mx-auto px-5 md:px-8 py-24 text-center">
      <p class="eyebrow text-[var(--color-brand-yellow-dark)]">Mensaje recibido</p>
      <h1 class="display text-5xl md:text-7xl mt-6">¡Gracias!</h1>
      <p class="mt-6 text-lg text-[var(--color-stone)] max-w-md mx-auto">
        Te responderemos en menos de 24 horas. Mientras tanto, síguenos en Instagram.
      </p>
      <div class="flex flex-wrap justify-center gap-3 mt-10">
        <a href={r('es', 'home')} class="btn btn-dark">Volver al inicio</a>
        <a href={r('es', 'expeditions')} class="btn btn-outline">Ver expediciones</a>
      </div>
    </div>
  </section>
</Base>
