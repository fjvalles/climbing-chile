---
import { getCollection } from 'astro:content';
import CourseDetail from '../../../components/CourseDetail.astro';

export async function getStaticPaths() {
  const entries = await getCollection('courses');
  return entries.map((entry) => ({ params: { slug: entry.data.slug || entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
---
<CourseDetail entry={entry} lang="en" />
