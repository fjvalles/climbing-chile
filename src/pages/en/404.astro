---
import Base from '../../layouts/Base.astro';
import { useTranslations } from '../../i18n/ui';

const lang = 'en';
const t = useTranslations(lang);
const title = 'Page not found';
---
<Base lang={lang} title={title}>
  <section class="flex-1 flex items-center justify-center py-20 bg-[var(--color-bone)] text-center">
    <div class="max-w-xl px-5">
      <p class="display text-8xl md:text-9xl text-[var(--color-brand-yellow-dark)] opacity-30">404</p>
      <h1 class="display text-4xl md:text-5xl mt-4">You seem to be lost on the mountain</h1>
      <p class="text-[var(--color-stone)] mt-6 text-lg leading-relaxed">
        The page you are looking for does not exist or has been moved to another summit.
      </p>
      <div class="mt-10">
        <a href="/en" class="btn btn-primary px-10 py-4">Back to base camp</a>
      </div>
    </div>
  </section>
</Base>
